# Cliente Firebase (mismo proyecto que Eaty)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Servidor (API Groq y sesión). Cuenta de servicio: Firebase → Project settings → Service accounts → Generate new private key.
# Usa UNA de estas (mismo JSON que el archivo descargado):
# - FIREBASE_SERVICE_ACCOUNT_JSON: JSON minificado en una sola línea (local o Vercel).
# - FIREBASE_SERVICE_ACCOUNT_JSON_BASE64: recomendado en Vercel — codifica el .json entero en Base64 (evita comillas rotas).
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("ruta\clave.json"))
#   macOS/Linux: base64 -i clave.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=
GROQ_API_KEY=

# Enlaces entre apps (cada una en su repo / dominio Vercel)
NEXT_PUBLIC_EATY_ORIGIN=http://localhost:3000
NEXT_PUBLIC_BODYMATTER_ORIGIN=http://localhost:3001

# Opcional: cookie de sesión compartida entre subdominios
# SERVER_SESSION_COOKIE_DOMAIN=.tudominio.com

# Cuotas Body Matter (Firestore users/{uid}/usage/{YYYY-MM-DD})
DAILY_GYM_TIPS_LIMIT=30
DAILY_GYM_ROUTINE_AI_LIMIT=15
